<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">
    <!--
        定义 fishbot_ros2_control 宏
        在主 xacro 文件中通过 <xacro:fishbot_ros2_control /> 调用
        作用：为 FishBot 添加 ros2_control 硬件接口和 Gazebo 控制插件
    -->
    <xacro:macro name="fishbot_ros2_control">
        <!--
            ros2_control 系统配置
            type="system" 表示这是一个完整机器人硬件系统
            name="FishBotGazeboSystem" 是该控制系统的名称
        -->
        <ros2_control name="FishBotGazeboSystem" type="system">
            <!--
                Gazebo 仿真硬件插件
                gazebo_ros2_control/GazeboSystem 用于连接 Gazebo 和 ros2_control
                作用：让 ros2_control 可以控制 Gazebo 中的关节
            -->
            <hardware>
                <plugin>gazebo_ros2_control/GazeboSystem</plugin>
            </hardware>
            <!-- ===================== 左轮关节控制接口 ===================== -->
            <!--
                左轮关节
                joint 名称必须与 URDF / xacro 中定义的左轮关节名一致
            -->
            <joint name="left_wheel_joint">
                <!--
                    速度控制接口
                    diff_drive_controller 通常使用 velocity 接口控制轮子转速
                    min / max 限制轮子速度指令范围
                -->
                <command_interface name="velocity">
                    <param name="min">-1</param>
                    <param name="max">1</param>
                </command_interface>
                <!--
                    力矩控制接口
                    如果使用 effort_controller，可通过 effort 控制轮子力矩
                    注意：不要和 diff_drive_controller 同时控制同一个关节
                -->
                <command_interface name="effort">
                    <param name="min">-0.1</param>
                    <param name="max">0.1</param>
                </command_interface>
                <!--
                    状态反馈接口
                    控制器可读取关节位置、速度和力矩状态
                -->
                <state_interface name="position" />
                <state_interface name="velocity" />
                <state_interface name="effort" />
            </joint>
            <!-- ===================== 右轮关节控制接口 ===================== -->
            <!--
                右轮关节，配置方式与左轮相同
            -->
            <joint name="right_wheel_joint">
                <!-- 右轮速度控制接口 -->
                <command_interface name="velocity">
                    <param name="min">-1</param>
                    <param name="max">1</param>
                </command_interface>
                <!-- 右轮力矩控制接口 -->
                <command_interface name="effort">
                    <param name="min">-0.1</param>
                    <param name="max">0.1</param>
                </command_interface>
                <!-- 右轮状态反馈接口 -->
                <state_interface name="position" />
                <state_interface name="velocity" />
                <state_interface name="effort" />
            </joint>
        </ros2_control>
        <!-- ===================== Gazebo ros2_control 插件 ===================== -->
        <gazebo>
            <!--
                加载 Gazebo ros2_control 插件
                该插件负责在 Gazebo 中启动 controller_manager
                并读取下面 parameters 指定的控制器 YAML 配置文件
            -->
            <plugin filename="libgazebo_ros2_control.so" name="gazebo_ros2_control">
                <!--
                    控制器参数文件路径
                    这里会加载 fishbot_ros2_controller.yaml
                    里面通常配置：
                    1. joint_state_broadcaster
                    2. diff_drive_controller
                    3. effort_controller
                -->
                <parameters>$(find fishbot_description)/config/fishbot_ros2_controller.yaml</parameters>
                <!-- ROS 话题重映射 -->
                <ros>
                    <!--
                        diff_drive_controller 默认订阅：
                        /fishbot_diff_drive_controller/cmd_vel_unstamped

                        这里重映射为：
                        /cmd_vel

                        这样 teleop_keyboard、Nav2 等发布 /cmd_vel 就可以直接控制小车
                    -->
                    <remapping>/fishbot_diff_drive_controller/cmd_vel_unstamped:=/cmd_vel</remapping>
                    <!--
                        将 diff_drive_controller 发布的里程计话题重映射为 /odom
                    -->
                    <remapping>/fishbot_diff_drive_controller/odom:=/odom</remapping>
                </ros>
            </plugin>
        </gazebo>
    </xacro:macro>
</robot>